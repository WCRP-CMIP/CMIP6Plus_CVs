{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "CMIP6 Source ID",
    "type": "object",
    "required": [
        "@id",
        "@type",
        "source_id:source_id",
        "source_id:label",
        "source_id:label_extended",
        "source_id:release_year",
        "source_id:activity_participation",
        "source_id:cohort",
        "source_id:institution_id",
        "source_id:contributers",
        "source_id:license",
        "source_id:model_component"
    ],
    "properties": {
        "@id": {
            "type": "string",
            "format": "uri",
            "pattern": "^cmip6plus:source/id/.+$"
        },
        "@type": {
            "type": "string",
            "pattern": "^cmip:source_id$"
        },
        "source_id:source_id": {
            "type": "string"
        },
        "source_id:label": {
            "type": "string"
        },
        "source_id:label_extended": {
            "type": "string"
        },
        "source_id:release_year": {
            "type": "integer",
            "minimum": 2000,
            "maximum": 2100
        },
        "source_id:activity_participation": {
            "type": "object",
            "properties": {
                "@set": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "@id": {
                                "type": "string",
                                "format": "uri",
                                "pattern": "^cmip6plus_cvs:activity/.+$"
                            }
                        },
                        "required": [
                            "@id"
                        ]
                    }
                }
            },
            "required": [
                "@set"
            ],
            "additionalProperties": false
        },
        "source_id:cohort": {
            "type": "string",
            "enum": [
                "published"
            ]
        },
        "source_id:institution_id": {
            "type": "object",
            "properties": {
                "@id": {
                    "type": "string",
                    "format": "uri",
                    "pattern": "^mip-cmor-tables:institutions/.+$"
                }
            },
            "required": [
                "@id"
            ],
            "additionalProperties": false
        },
        "source_id:contributers": {
            "type": "object",
            "properties": {
                "@set": {
                    "type": "object"
                }
            },
            "required": [
                "@set"
            ],
            "additionalProperties": false
        },
        "source_id:license": {
            "type": "object",
            "properties": {
                "@nest": {
                    "type": "object",
                    "properties": {
                        "license:type": {
                            "type": "object",
                            "properties": {
                                "@id": {
                                    "type": "string",
                                    "format": "uri",
                                    "pattern": "^mip-cmor-tables:license/.+$"
                                }
                            },
                            "required": [
                                "@id"
                            ],
                            "additionalProperties": false
                        },
                        "license:exceptions_contact": {
                            "type": "string"
                        },
                        "license:source_specific_info": {
                            "type": "string"
                        }
                    },
                    "required": [
                        "license:type",
                        "license:exceptions_contact",
                        "license:source_specific_info"
                    ],
                    "additionalProperties": false
                }
            },
            "required": [
                "@nest"
            ],
            "additionalProperties": false
        },
        "source_id:model_component": {
            "type": "object",
            "properties": {
                "@list": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "@id": {
                                "type": "string",
                                "format": "uri",
                                "pattern": "^cmip6plus:model/componets/.+$"
                            }
                        },
                        "required": [
                            "@id"
                        ]
                    }
                }
            },
            "required": [
                "@list"
            ],
            "additionalProperties": false
        }
    },
    "additionalProperties": false
}